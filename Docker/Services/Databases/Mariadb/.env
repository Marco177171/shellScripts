CXX="c++"
CC="gcc"

DBI_USER="root"
DBI_TRACE="0"

HOME="/root"
TMPDIR="/tmp"

MYSQL_DEBUG="0"
MYSQL_GROUP_SUFFIX=""
MYSQL_HISTFILE="~/.mysql_history"
MYSQL_HOME="/usr"
MYSQL_HOST="localhost"
MYSQL_PS1="\u@\h [\d]>\_"
MYSQL_PWD="your_password_here"
MYSQL_TCP_PORT="3306"
MYSQL_UNIX_PORT="/var/run/mysqld/mysqld.sock"

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin"
TZ="UTC"
UMASK="0077"
UMASK_DIR="0077"
USER="mariadb_user"
EXTERNAL_PORT="3306"

MARIADB_AUTO_UPGRADE="1"
MARIADB_ROOT_HOST="localhost"
MARIADB_DATABASE="database"
MARIADB_USER="username"
MARIADB_PASSWORD="password"
MARIADB_ROOT_PASSWORD="password"
# MARIADB_ROOT_PASSWORD_HASH="rootpasswordhash"
MARIADB_ALLOW_EMPTY_ROOT_PASSWORD="false"
MYSQL_ALLOW_EMPTY_PASSWORD="false"
# MARIADB_RANDOM_ROOT_PASSWORD="randomrootpassword"
